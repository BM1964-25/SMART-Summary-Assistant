#!/bin/zsh

BUNDLED_ROOT="$(cd "$(dirname "$0")/../Resources/App" && pwd)"
APP_ROOT="${BUNDLED_ROOT}"
PORT="8182"
URL="http://127.0.0.1:${PORT}"
NODE_BIN="/opt/homebrew/bin/node"
LOG_DIR="${APP_ROOT}/logs"
LOG_FILE="${LOG_DIR}/server.log"

if [ ! -x "$NODE_BIN" ]; then
  NODE_BIN="/usr/bin/env node"
fi

cd /tmp || exit 1
/bin/mkdir -p "${LOG_DIR}"

if ! /usr/bin/curl --silent --fail "${URL}" >/dev/null 2>&1; then
  /usr/bin/env PORT="${PORT}" /usr/bin/nohup $NODE_BIN "${APP_ROOT}/localProxyServer.js" >>"${LOG_FILE}" 2>&1 &
  for attempt in {1..30}; do
    if /usr/bin/curl --silent --fail "${URL}" >/dev/null 2>&1; then
      break
    fi
    /bin/sleep 0.2
  done
fi

/usr/bin/open "${URL}"
